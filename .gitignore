# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/artifacts/

# next.js
/.next/
/out/
**/.next/
**/out/
**/.swc/

# production
/dist
**/dist/

# misc
.DS_Store
*.pem
.tools/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.logs/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local app data
data/localMemories.private.json
data/cityAssets.private.json
data/loginPhotos.private.json
data/*.backup-*
backend/data/

# local tool state and downloaded SDK bundles
tmp/
.kimchi/
jpush-android-*.zip

# archived generated/source assets not used by the app
/archive/
/awesome-design-md/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
