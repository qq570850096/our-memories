# Our Memories - Go/SQLite API

# Server
PORT=8080
GIN_MODE=release

# Database and static files
DATABASE_PATH=./backend/data/ourMemories.db
PUBLIC_DIR=./backend/public

# Security. Production must use a long random value:
# openssl rand -base64 32
JWT_SECRET=your-secure-random-string-at-least-24-characters-long

# Same-origin deployment does not require CORS for the browser app, but these
# origins are useful for local Next.js dev servers and mobile shells.
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3003,http://localhost:8080,http://your-server-ip,capacitor://localhost,http://localhost,https://localhost

# Initial private space
DEFAULT_SPACE_CODE=our-space-2026
DEFAULT_PASSWORD=
AUTO_SEED=false

# Admin panel account. Set these in production to auto-create/update admin login.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Admin User

# S3-compatible object storage. Leave blank to use local upload fallback where supported.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=our-memories
S3_PUBLIC_BASE_URL=
S3_OBJECT_ACL=

# DeepSeek API for AI text polishing
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Optional anniversary defaults
DEFAULT_ANNIVERSARY_DATE=2020-01-01
DEFAULT_ANNIVERSARY_LABEL=在一起

# Web build. Leave empty for same-origin deployments where /api/v1 is served by
# the same domain. Only set this when frontend/backend are split.
NEXT_PUBLIC_API_BASE_URL=

# Android online APK. The APK should load an HTTPS URL in production.
CAPACITOR_SERVER_URL=
JPUSH_APP_KEY=0ff236477b0e10b5d960163e

# Server-side JPush API credentials. Do not expose this in frontend/mobile bundles.
JPUSH_MASTER_SECRET=
